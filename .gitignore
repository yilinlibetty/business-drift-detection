# 1. 忽略 Python 缓存和环境
__pycache__/
*.pyc
.venv/
venv/
.idea/
.vscode/

# 2. 忽略生成的临时报告文件 (在 GitLab 上保持干净)
*.json
*.txt
*.md

# 3. 但是要保留文档与示例
!README.md
!requirements.txt
!examples/Final_Drift_Analysis_Report.md

# 4. 统一忽略 outputs 目录中的运行产物
outputs/*
!outputs/.gitkeep

# 5. 忽略 Mac/Windows 系统文件
.DS_Store
Thumbs.db
